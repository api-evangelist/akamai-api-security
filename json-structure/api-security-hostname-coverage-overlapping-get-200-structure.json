{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/akamai-api-security/refs/heads/main/json-structure/api-security-hostname-coverage-overlapping-get-200-structure.json",
  "name": "hostname-coverage-overlapping-get-200",
  "description": "Describes configurations that use the same hostname, causing overlapping coverage.",
  "type": "object",
  "properties": {
    "overLappingList": {
      "description": "The list of configurations that overlap coverage for the hostname.",
      "items": {
        "additionalProperties": false,
        "description": "Contains details about an overlapping configuration.",
        "properties": {
          "configId": {
            "description": "The configuration ID.",
            "type": "int32"
          },
          "configName": {
            "description": "The configuration name.",
            "type": "string"
          },
          "configVersion": {
            "description": "The configuration version.",
            "type": "int32"
          },
          "contractId": {
            "description": "The contract ID.",
            "type": "string"
          },
          "contractName": {
            "description": "The contract name.",
            "type": "string"
          },
          "hostnames": {
            "description": "List of version tags, any combination of `STAGING` and `LAST_CREATED`.",
            "items": {
              "description": "The version tag.",
              "enum": [
                "STAGING",
                "LAST_CREATED"
              ],
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "configId",
          "configName",
          "configVersion"
        ],
        "type": "object",
        "x-akamai": {
          "file-path": "schemas/overlap-config.yaml"
        }
      },
      "type": "array"
    }
  },
  "required": [
    "overLappingList"
  ],
  "additionalProperties": false
}